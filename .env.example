# Environment
NODE_ENV=development

# MySQL (utf8mb4 charset)
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=coffee_shop_db
MYSQL_USER=coffee_user
MYSQL_PASSWORD=coffee_password_change_me
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci

# Redis
REDIS_PASSWORD=redis_password_change_me

# RabbitMQ
RABBITMQ_USER=coffee_rabbit
RABBITMQ_PASSWORD=rabbit_password_change_me

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_me
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Encryption (AES-256-GCM)
ENCRYPTION_KEY=change_this_to_32_char_min_secure_key!

# Admin Seed
ADMIN_EMAIL=admin@coffeeshop.com
ADMIN_PASSWORD=change_this_admin_password!

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Coffee Shop <noreply@coffeeshop.com>

# Frontend (CRA — build uses /api via nginx proxy)
REACT_APP_API_URL=http://localhost:3000/api

# Cloudflare Tunnel (optional)
# CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token
